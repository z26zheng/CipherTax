# CipherTax Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for Claude integration)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Claude model to use (optional, defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Vault encryption password (optional — if not set, one will be auto-generated)
# VAULT_PASSWORD=your-secure-password-here

# Tesseract binary path (optional — auto-detected on most systems)
# TESSERACT_CMD=/usr/local/bin/tesseract
